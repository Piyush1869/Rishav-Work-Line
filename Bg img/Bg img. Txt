// --- SETUP (Audit History removed, handled dynamically now) ---
function ensureSetup() {
  const ss = SpreadsheetApp.openById(SHEET_ID);
  const requiredSheets = {
    'Instruments': ['Lab Serial Number', 'Instrument Name', 'Serial Number', 'Ratings', 'Status', 'Location / Used By', 'Remarks', 'Audit By', 'Last Audit Date'],
    'Tools': ['Serial Number', 'Tool Name', 'Status', 'Remarks', 'Last Audit Date', 'Audit By'],
    'Users': ['User Name'],
    'Borrowers': ['Emp ID', 'Name', 'Mobile', 'Item Type', 'Item Name/Serial', 'Purpose', 'Borrow Date', 'Return Date', 'Given By', 'Status']
  };

  for (const sheetName in requiredSheets) {
    let sheet = ss.getSheetByName(sheetName);
    if (!sheet) { sheet = ss.insertSheet(sheetName); }
    
    const expectedHeaders = requiredSheets[sheetName];
    if (sheet.getLastRow() === 0) {
      sheet.appendRow(expectedHeaders);
    } else {
      const currentFirstCell = String(sheet.getRange(1, 1).getDisplayValue()).trim();
      if (currentFirstCell !== expectedHeaders[0]) {
        sheet.insertRowBefore(1);
        sheet.getRange(1, 1, 1, expectedHeaders.length).setValues([expectedHeaders]);
      }
    }
  }
}

function getAppData() {
  try {
    ensureSetup(); 
    const ss = SpreadsheetApp.openById(SHEET_ID);
    return {
      success: true,
      instruments: safeGetData(ss.getSheetByName('Instruments')),
      tools: safeGetData(ss.getSheetByName('Tools')),
      users: safeGetUsers(ss.getSheetByName('Users')),
      borrowers: safeGetData(ss.getSheetByName('Borrowers'))
    };
  } catch (err) {
    return { success: false, error: err.toString() };
  }
}

// --- INSTRUMENTS (Now creates dynamic Date columns horizontally) ---
function processInstrument(labSerial, status, remarks, locationUsedBy, auditBy) {
  ensureSetup(); 
  const ss = SpreadsheetApp.openById(SHEET_ID);
  const sheet = ss.getSheetByName('Instruments');
  
  const data = sheet.getDataRange().getDisplayValues(); 
  const headers = data[0];
  const today = new Date().toLocaleDateString();
  
  // Check if today's date column exists, if not, create it!
  let dateColIndex = headers.indexOf(today);
  if (dateColIndex === -1) {
    let nextCol = sheet.getLastColumn() + 1;
    sheet.getRange(1, nextCol).setValue(today);
    sheet.getRange(1, nextCol + 1).setValue(today + ' Remarks');
    dateColIndex = nextCol - 1; // Array index is 0-based
  }
  
  const searchSerial = String(labSerial).trim().toLowerCase();

  for (let i = 1; i < data.length; i++) {
    const sheetSerial = String(data[i][0]).trim().toLowerCase();

    if (sheetSerial === searchSerial) {
      // 1. Update the Main Columns (so Dashboard tracks properly)
      sheet.getRange(i + 1, 5).setValue(status);         
      sheet.getRange(i + 1, 6).setValue(locationUsedBy); 
      sheet.getRange(i + 1, 7).setValue(remarks);        
      sheet.getRange(i + 1, 8).setValue(auditBy);        
      sheet.getRange(i + 1, 9).setValue(today);          
      
      // 2. Update the specific Date and Date Remarks columns at the end of the sheet
      sheet.getRange(i + 1, dateColIndex + 1).setValue(status);
      sheet.getRange(i + 1, dateColIndex + 2).setValue(remarks);

      return { success: true, message: `Updated ${data[i][1]}` };
    }
  }
  return { success: false, message: "Serial not found!" };
}

// --- TOOLS (Now creates dynamic Date columns horizontally) ---
function updateTool(serial, status, remarks, auditBy) {
  ensureSetup();
  const ss = SpreadsheetApp.openById(SHEET_ID);
  const sheet = ss.getSheetByName('Tools');

  const data = sheet.getDataRange().getDisplayValues();
  const headers = data[0];
  const today = new Date().toLocaleDateString();

  // Check if today's date column exists, if not, create it!
  let dateColIndex = headers.indexOf(today);
  if (dateColIndex === -1) {
    let nextCol = sheet.getLastColumn() + 1;
    sheet.getRange(1, nextCol).setValue(today);
    sheet.getRange(1, nextCol + 1).setValue(today + ' Remarks');
    dateColIndex = nextCol - 1; 
  }

  for (let i = 1; i < data.length; i++) {
    if (data[i][0] == serial) {
      // 1. Update the Main Columns
      sheet.getRange(i + 1, 3).setValue(status);
      sheet.getRange(i + 1, 4).setValue(remarks);
      sheet.getRange(i + 1, 5).setValue(today);
      sheet.getRange(i + 1, 6).setValue(auditBy);

      // 2. Update the specific Date and Date Remarks columns at the end of the sheet
      sheet.getRange(i + 1, dateColIndex + 1).setValue(status);
      sheet.getRange(i + 1, dateColIndex + 2).setValue(remarks);

      return { success: true };
    }
  }
}

// --- USERS & BORROWERS ---
function manageUser(action, userName) {
  const sheet = SpreadsheetApp.openById(SHEET_ID).getSheetByName('Users');
  if (action === 'add') { sheet.appendRow([userName]); } 
  else if (action === 'delete') {
    const data = sheet.getDataRange().getDisplayValues();
    for (let i = 1; i < data.length; i++) {
      if (data[i][0] === userName) { sheet.deleteRow(i + 1); break; }
    }
  }
  return true;
}

function addBorrower(empId, name, mobile, type, item, purpose, returnDate, givenBy) {
  ensureSetup();
  const sheet = SpreadsheetApp.openById(SHEET_ID).getSheetByName('Borrowers');
  const today = new Date().toLocaleDateString();
  sheet.appendRow([empId, name, mobile, type, item, purpose, today, returnDate, givenBy, 'Borrowed']);
  return true;
}

function returnItem(empId, item) {
  const sheet = SpreadsheetApp.openById(SHEET_ID).getSheetByName('Borrowers');
  const data = sheet.getDataRange().getDisplayValues();
  for (let i = 1; i < data.length; i++) {
    if (data[i][0] == empId && data[i][4] == item && data[i][9] == 'Borrowed') {
      sheet.getRange(i + 1, 10).setValue('Returned');
      return true;
    }
  }
}

// --- HELPERS ---
function safeGetData(sheet) {
  if (!sheet || sheet.getLastRow() <= 1) return []; 
  const data = sheet.getDataRange().getDisplayValues(); 
  const headers = data.shift();
  return data.map(row => {
    let obj = {};
    headers.forEach((header, i) => obj[header] = row[i]);
    return obj;
  });
}

function safeGetUsers(sheet) {
  if (!sheet || sheet.getLastRow() <= 1) return [];
  return sheet.getDataRange().getDisplayValues().flat().filter(String).slice(1);
}
